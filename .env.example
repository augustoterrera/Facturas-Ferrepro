# ===== Dux =====
DUX_TOKEN=pega-aca-tu-token-de-dux
DUX_BASE=https://erp.duxsoftware.com.ar/WSERP/rest/services
# Una o varias empresas separadas por coma: 3526  |  3526,1234
DUX_ID_EMPRESA=3526
# Segundos entre requests. Dux exige >=5; en tandas largas conviene 6-7.
DUX_RATE_DELAY=7
# Cuántas facturas se mandan por RPC (sync_facturas_dux acepta lotes).
DUX_BATCH_SIZE=50

# ===== Supabase =====
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# ===== Sync =====
# Re-chequeo de los últimos N días en cada corrida (captura anulaciones/cambios).
DUX_VENTANA_DIAS=35
# Desde cuándo trae la PRIMERA vez (cuando todavía no hay watermark).
DUX_BACKFILL_DESDE=2024-01-01
# Cada cuántos minutos corre el sync incremental (ventana móvil).
SYNC_INTERVAL_MIN=30
# Cron (UTC) del re-sync COMPLETO que capta ediciones/anulaciones viejas.
# Default: lunes 06:00 UTC (03:00 ART). Vacío = deshabilitado.
FULL_RESYNC_CRON=0 6 * * 1
# true = dispara un sync apenas arranca el contenedor.
SYNC_ON_START=false

# ===== Deploy =====
# Puerto del HOST donde se publica el servicio (mapeado al 8000 del contenedor).
# SIEMPRE se bindea a 127.0.0.1 (no se expone a internet). En el VPS el 8000 ya
# está ocupado por otra app, así que ahí poné HOST_PORT=8011.
HOST_PORT=8000

# ===== Operación =====
LOG_LEVEL=INFO
# Nombre del RPC de carga en tu base (el cargador real ya existe).
SYNC_RPC=sync_facturas_dux
