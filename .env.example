# ===== Dux =====
DUX_TOKEN=pega-aca-tu-token-de-dux
DUX_BASE=https://erp.duxsoftware.com.ar/WSERP/rest/services
# Una o varias empresas separadas por coma: 3526  |  3526,1234
DUX_ID_EMPRESA=3526
# Segundos entre requests. Dux exige >=5; en tandas largas conviene 6-7.
DUX_RATE_DELAY=7
# Cuántas facturas se mandan por RPC (sync_facturas_dux acepta lotes).
DUX_BATCH_SIZE=50

# ===== Supabase =====
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# ===== Sync =====
# Re-chequeo de los últimos N días en cada corrida (captura anulaciones/cambios).
DUX_VENTANA_DIAS=35
# Desde cuándo trae la PRIMERA vez (cuando todavía no hay watermark).
DUX_BACKFILL_DESDE=2024-01-01
# Cada cuántos minutos corre el sync incremental (ventana móvil).
SYNC_INTERVAL_MIN=30
# Cron (UTC) del re-sync COMPLETO que capta ediciones/anulaciones viejas.
# Default: lunes 06:00 UTC (03:00 ART). Vacío = deshabilitado.
FULL_RESYNC_CRON=0 6 * * 1
# true = dispara un sync apenas arranca el contenedor.
SYNC_ON_START=false

# ===== Deploy =====
# Puerto del HOST donde se publica el servicio (mapeado al 8000 del contenedor).
# SIEMPRE se bindea a 127.0.0.1 (no se expone a internet). En el VPS el 8000 ya
# está ocupado por otra app, así que ahí poné HOST_PORT=8011.
HOST_PORT=8000

# ===== Alertas (Telegram) =====
# Bot de @BotFather + chat destino. Si quedan vacíos, NO se envían alertas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Nombre que aparece en la alerta, para distinguir de qué proyecto viene.
ALERT_PROJECT=facturas-ferrepro

# ===== Operación =====
LOG_LEVEL=INFO
# Nombre del RPC de carga en tu base (el cargador real ya existe).
SYNC_RPC=sync_facturas_dux

# ===== Tiendanube / Productos =====
TIENDANUBE_API_VERSION=2025-03
TIENDANUBE_STORE_ID=4778549
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT="AgenteIA equipo@waichatt.com"
TIENDANUBE_ONLY_PUBLISHED=true
TIENDANUBE_OVERLAP_MINUTES=5
TIENDANUBE_RATE_DELAY=0.6

# Productos/RAG: reemplaza los workflows "RAG" y "Reconciliación".
PRODUCTOS_SYNC_INTERVAL_HOURS=6
# 04:00 ART = 07:00 UTC, porque APScheduler corre en UTC.
PRODUCTOS_RECONCILE_CRON=0 7 * * *
PRODUCTOS_SYNC_STATE_TABLE=ferrepro_sync_state
PRODUCTOS_SYNC_STATE_ID=1
PRODUCTOS_UPSERT_RPC=ferrepro_upsert_producto
PRODUCTOS_RECONCILE_RPC=ferrepro_reconciliar

# ===== OpenAI / Embeddings =====
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Meta Ads =====
META_API_VERSION=v24.0
META_AD_ACCOUNT_ID=1157987296120903
META_ACCESS_TOKEN=
META_TIMEZONE=America/Argentina/Tucuman
META_BACKFILL_MONTHS=37
META_INSIGHTS_LIMIT=500
META_INSIGHTS_TABLE=meta_insights_daily
META_RATE_DELAY=0.5
META_SYNC_INTERVAL_HOURS=24
